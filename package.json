{
  "name": "agentic-resume-builder",
  "version": "1.0.0",
  "description": "Desktop resume builder with a local Electron app shell.",
  "author": "Self Tool",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch --disable-warning=ExperimentalWarning server.ts",
    "start": "node --disable-warning=ExperimentalWarning server.ts",
    "client": "vite --host 0.0.0.0 --port 3501 --strictPort",
    "build": "npm run typecheck && vite build && npm run build:electron",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist-electron/main.mjs --external:electron",
    "prepare:electron": "node -e \"require('electron')\"",
    "app:dev": "npm run build:electron && set VITE_DEV_SERVER_URL=http://localhost:3501&& concurrently \"npm run client\" \"electron .\"",
    "app:dir": "npm run build && npm run prepare:electron && electron-builder --dir",
    "app:build": "npm run app:dir && electron-builder --win nsis --x64 --prepackaged release/win-unpacked",
    "preview": "vite preview --host 0.0.0.0 --port 3501 --strictPort",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.561.0",
    "pdfkit": "^0.19.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pdfkit": "^0.13.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.2"
  },
  "build": {
    "appId": "com.selftool.resume-builder",
    "productName": "Sox Resume Builder",
    "npmRebuild": false,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
