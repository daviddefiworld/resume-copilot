{
  "name": "agentic-resume-builder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server.ts",
    "start": "node server.ts",
    "client": "vite --host 0.0.0.0 --port 3501 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3501 --strictPort",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.561.0",
    "pdfkit": "^0.19.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pdfkit": "^0.13.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.8.2"
  }
}
